{
  "type" : "source",
  "canonicalizer" : "system",
  "format" : {
    "name" : "avro-confluent",
    "url" : "${ENV_URL:-some_value}",
    "basic-auth.credentials-source": "myauth"
  },
  "name" : "orders",
  "identifier" : "orders",
  "schema" : "avro",
  "connector" : {
    "name" : "kafka",
    "bootstrap.servers": "${KAFKA_BROKERS}",
    "scan.startup.mode": "${sys:-datasqrl.something}",
    "sink.partitioner": "default",
    "group.id": "mygroupid"
  }
}
