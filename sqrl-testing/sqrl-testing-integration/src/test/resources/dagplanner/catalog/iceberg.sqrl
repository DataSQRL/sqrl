CREATE CATALOG iceberg WITH (
    'type' = 'iceberg',
    'catalog-type' = 'hadoop',
    'warehouse' = 'file:///tmp/iceberg/warehouse'
);

USE CATALOG iceberg;

CREATE DATABASE IF NOT EXISTS my_database;
USE my_database;

CREATE TABLE IF NOT EXISTS my_table  (
    key_col STRING,
    int_col INT
) WITH (
    'format-version' = '2'
);
