/*+ engine(kafka) */
CREATE TABLE _SensorsValid (
    sensorid INT,
    machineid INT,
    updatedTime TIMESTAMP_LTZ(3) METADATA FROM 'timestamp',
    PRIMARY KEY (sensorid) NOT ENFORCED
);

/**
  Multi-line doc comment
  */
CREATE TABLE _SensorsInvalid (
    sensorid INT,
    machineid INT,
    updatedTime TIMESTAMP_LTZ(3) METADATA FROM 'timestamp',
    PRIMARY KEY (sensorid) NOT ENFORCED
);

Sensors := SELECT * FROM _SensorsValid;
