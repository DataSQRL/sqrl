{
  "version": "1",
  "enabled-engines": ["flink", "kafka"],
  "script": {
    "main": "flink-kafka.sqrl",
    "shared": {
      "banking-catalog": {
        "path": "../banking-shared",
        "config": {
          "monitorInterval": "5s"
        }
      }
    }
  },
  "test-runner": {
    "delay-sec": -1,
    "required-checkpoints": 1,
    "create-topics": ["input_topic1", "input_topic2"]
  }
}
