{
  "version": 1,
  "flink" : {
    "format" : "json",
    "path" : "${DATA_PATH}",
    "connector" : "filesystem"
  },
  "table" : {
    "type" : "source",
    "primary-key" : ["id", "placed"],
    "timestamp" : "placedTimestamp",
    "watermark-millis" : "1"
  },
  "metadata" : {
    "placedTimestamp" : {
      "attribute" : "time.epochMilliToTimestamp(placed)"
    }
  }
}